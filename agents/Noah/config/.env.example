# Do NOT store real secrets here. Fill in CI/Secrets manager.
DATABASE_URL=postgres://user:password@localhost:5432/appdb
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=replace_with_random_32_bytes
JWT_ACCESS_EXP=15m
JWT_REFRESH_EXP=7d
BCRYPT_COST=12
# Feature flags
FEATURE_AUTH_ROTATION=true
# Rate limits
RATE_LIMIT_LOGIN_PER_IP=10
RATE_LIMIT_GENERAL_PER_USER=100
